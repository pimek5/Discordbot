# Discord Bot Token
# Pobierz z: https://discord.com/developers/applications
BOT_TOKEN=your_bot_token_here

# yt-dlp YouTube authentication (set one of the options below)
# Option 1: cookies file exported from browser extension
# YTDL_COOKIES_FILE=./cookies.txt

# Option 1b (hosting-friendly): full cookies content in env
# Supports plain Netscape cookie text or base64 string
# YTDL_COOKIES_DATA=

# Option 2: direct browser cookies access
# Examples: chrome , chrome:Default , firefox:default-release
# YTDL_COOKIES_FROM_BROWSER=chrome:Default

# Optional separate profile variable (used when YTDL_COOKIES_FROM_BROWSER has only browser name)
# YTDL_COOKIES_PROFILE=Default
